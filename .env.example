# A hg25ccs titkai. Másold .env néven a hg25ccs/ mappába.
# A .gitignore már kizárja a .env-et, szóval nem kerül be a repóba.

# Az admin session tokenek aláírókulcsa (auth.py).
# ⚠️ ÉLESBEN cseréld le: openssl rand -hex 32
CCS_AUTH_SECRET=change-this-ccs-admin-secret

# Admin belépés élettartama másodpercben (alapértelmezés: 12 óra).
CCS_AUTH_TTL=43200
